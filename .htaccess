# Serve the PWA directly, bypassing NextCloud's front controller.
# Needed when the app is deployed inside a NextCloud webroot subfolder so
# Apache serves index.html instead of falling through to NextCloud's index.php.
DirectoryIndex index.html
RewriteEngine On
# Serve any file/dir that actually exists, then stop further rewriting.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# NextCloud's root .htaccess sets a 6-month expiry on JS/CSS, which otherwise
# applies here too and makes Cloudflare/browsers cache the app shell for months
# (so updates — especially the service worker — never get picked up). Disable
# it for this folder and require revalidation instead.
<IfModule mod_expires.c>
  ExpiresActive Off
</IfModule>
<IfModule mod_headers.c>
  # NextCloud sets its cache header inside an <If>/<Else>, which Apache merges
  # AFTER plain <FilesMatch> blocks. To override it we must also use <If>, so our
  # directive lands in the same (last) merge phase and wins from this deeper
  # .htaccess.
  <If "true">
    Header set Cache-Control "no-cache, must-revalidate"
  </If>
</IfModule>
